{
  "htmlCode": "<div class=\"flags-container\">\n<div class=\"flags\">\nTHING GOES HERE\n</div>\n</div>\n\n<style>\n@import url(https://SITEID.wdfiles.com/local--code/component%3Atheme/1);\n@import url(https://SITEID.wdfiles.com/local--code/theme%3ATHEME/1);\n@import url(https://SITEID.wdfiles.com/local--code/theme%3ATHEME/2);\n\n:root {\n--link-color: var(--rating-module-text-color);\n--hover-link-color: var(--rating-module-text-color);\n--visited-link-color: var(--rating-module-text-color);\n}\nhtml {\nmax-height: calc(var(--rating-module-height) * 2.75);\n}\nbody {\nbackground: 0;\n}\n.flags-container {\nmax-height: calc(var(--rating-module-height) * 2.75);\nheight: calc(var(--rating-module-height) * 2.75);\noverflow: scroll;\n}\n.flags {\nwidth: 100%;\nmin-height: 100%;\nheight: fit-content;\nborder: 3px blue;\ndisplay: -webkit-box;\ndisplay: -webkit-flex;\ndisplay: -moz-box;\ndisplay: -ms-flexbox;\ndisplay: flex;\njustify-content: center;\nflex-direction: column;\n}\n.expanded {\nfont-family: var(--UI-font);\nfont-size: 1em;\ntext-transform: capitalize;\nbackground-color: transparent;\nborder: none;\npadding-left: .25em;\nfont-weight: 600;\nbackground: 0 0;\nbackground-color: rgb(0, 0, 0, 0);\nposition: relative;\nword-break: normal;\nhyphens: manual;\nfont-optical-sizing: auto;\ntext-decoration: none !important;\n}\na.expanded::after, a.expanded::before, a.expanded:hover::after, a.expanded:hover::before, a.expanded:target::after, a.expanded:target::before, a.expanded:focus::after, a.expanded:focus::before {\ncontent: none;\n}\nimg.image {\nwidth: 20px;\n}\n</style>"
